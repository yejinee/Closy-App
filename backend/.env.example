# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose로 띄운 로컬 PostgreSQL (db 서비스명 사용)
DATABASE_URL=postgresql+asyncpg://closy:closy1234@db:5432/closy_dev

# ─── Gemini API ──────────────────────────────────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT 인증 ─────────────────────────────────────────────────────────────────
# 프로덕션에서는 반드시 강력한 랜덤 문자열로 교체
SECRET_KEY=your_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── 앱 환경 ──────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:8081", "http://localhost:19006"]

# ─── Google Vision AI ─────────────────────────────────────────────────────────
# 방법 1) 서비스 계정 JSON 파일 경로 (로컬 개발 권장)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/closy-vision-key.json
# 방법 2) JSON 내용 직접 입력 (배포 환경 권장, 방법 1과 택1)
# GOOGLE_VISION_KEY_JSON={"type":"service_account","project_id":"..."}
